APP_ENV=development
APP_PORT=4000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql+asyncpg://feedstudio:feedstudio@postgres:5432/feedstudio

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=feedstudio
MINIO_SECRET_KEY=feedstudio-secret
MINIO_BUCKET=feedstudio-uploads
MINIO_SECURE=false
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

UPLOAD_MAX_FILES=10
UPLOAD_MAX_FILE_BYTES=10485760

DB_RESET_ON_START=false
AI_EXECUTION_RETENTION_DAYS=30
BACKEND_INTERNAL_API_KEY=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_MAX_TOKENS=8192
OPENROUTER_TEMPERATURE=0.9
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Feedstudio
RABBITMQ_URL=amqp://feedstudio:feedstudio@rabbitmq:5672/
RABBITMQ_GENERATE_QUEUE=generate_posts
RABBITMQ_PREFETCH_COUNT=10
