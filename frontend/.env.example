# Frontend environment contract
# Copy to .env.local for local overrides.

NODE_ENV=development

# Server-side only: used by Next.js rewrites and server fetches.
BACKEND_URL=http://localhost:4000
BACKEND_INTERNAL_API_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Public: used by the browser HTTP client.
# Keep /api/backend when the Next.js rewrite should proxy requests.
NEXT_PUBLIC_BACKEND_URL=/api/backend
